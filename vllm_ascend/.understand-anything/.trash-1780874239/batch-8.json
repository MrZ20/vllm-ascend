    {
      "id": "file:cpu_binding.py",
      "type": "file",
      "name": "cpu_binding.py",
      "filePath": "cpu_binding.py",
      "summary": "为 Ascend NPU 工作进程实现 CPU 亲和性绑定，依据 NPU 拓扑与 NUMA 节点信息将线程、内存和 NPU 中断（IRQ）分配到合适的 CPU 核心上，以优化推理性能。",
      "tags": ["utility", "cpu-binding", "numa", "performance", "device-affinity"],
      "complexity": "complex",
      "languageNotes": "通过解析 npu-smi、lscpu、/proc 等系统命令输出构建 NPU 与 CPU/NUMA 的映射关系，使用 taskset、numactl 等工具完成绑核。"
    },
    {
      "id": "class:cpu_binding.py:DeviceInfo",
      "type": "class",
      "name": "DeviceInfo",
      "filePath": "cpu_binding.py",
      "lineRange": [54, 153],
      "summary": "采集并解析 NPU 设备拓扑信息，包括逻辑 NPU 编号、允许使用的 CPU 列表、正在运行的 NPU 以及 NPU 的 CPU 亲和性映射。",
      "tags": ["data-model", "device-info", "npu-topology", "parsing"],
      "complexity": "moderate"
    },
    {
      "id": "class:cpu_binding.py:CpuAlloc",
      "type": "class",
      "name": "CpuAlloc",
      "filePath": "cpu_binding.py",
      "lineRange": [156, 529],
      "summary": "核心绑核分配器，构建 CPU 资源池并按 NUMA 节点为每个 NPU 划分 CPU，随后执行线程绑定、内存绑定与 NPU IRQ 绑定的完整流程。",
      "tags": ["service", "cpu-allocation", "numa", "irq-binding", "scheduling"],
      "complexity": "complex"
    },
    {
      "id": "function:cpu_binding.py:bind_cpus",
      "type": "function",
      "name": "bind_cpus",
      "filePath": "cpu_binding.py",
      "lineRange": [532, 537],
      "summary": "对外暴露的入口函数，在 ARM CPU 上为指定 rank 创建 CpuAlloc 实例并执行完整的绑核流程。",
      "tags": ["entry-point", "cpu-binding", "utility"],
      "complexity": "simple"
    },
    {
      "id": "file:distributed/device_communicators/pyhccl_wrapper.py",
