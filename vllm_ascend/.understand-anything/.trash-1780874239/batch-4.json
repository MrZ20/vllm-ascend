    {
      "id": "file:eplb/core/policy/policy_default_eplb.py",
      "type": "file",
      "name": "policy_default_eplb.py",
      "filePath": "eplb/core/policy/policy_default_eplb.py",
      "summary": "默认 EPLB 策略实现，通过冗余专家分配与均衡装箱（balanced pack）算法对各层 MoE 专家在 NPU 设备间进行负载重平衡。",
      "tags": ["eplb", "moe", "load-balancing", "service", "numpy"],
      "complexity": "complex",
      "languageNotes": "基于 numpy 实现贪心装箱与冗余专家放置算法，按各层专家热度（workload）做均衡。"
    },
    {
      "id": "class:eplb/core/policy/policy_default_eplb.py:DefaultEplb",
      "type": "class",
      "name": "DefaultEplb",
      "filePath": "eplb/core/policy/policy_default_eplb.py",
      "lineRange": [27, 350],
      "summary": "默认专家重平衡策略，包含冗余专家添加、均衡装箱、热度计算与本地交换约束等核心逻辑，输出新的全局专家部署方案。",
      "tags": ["eplb", "moe", "load-balancing", "bin-packing", "numpy"],
      "complexity": "complex"
    },
    {
      "id": "file:eplb/core/policy/policy_factory.py",
