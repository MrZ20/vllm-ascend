    {
      "id": "file:xlite/utils.py",
      "type": "file",
      "name": "utils.py",
      "filePath": "xlite/utils.py",
      "summary": "提供递归属性访问的工具函数，支持以点分路径安全读取嵌套模型对象的属性，供 xlite 适配层在权重映射时使用。",
      "tags": ["utility", "attribute-access", "helper"],
      "complexity": "simple",
      "languageNotes": "使用 functools.reduce 风格实现 rgetattr，支持点分路径递归取值并带默认值回退。"
    },
    {
      "id": "file:xlite/xlite_model_runner.py",
      "type": "file",
      "name": "xlite_model_runner.py",
      "filePath": "xlite/xlite_model_runner.py",
      "summary": "继承 NPU model runner，将加载后的模型包装为 XliteWrapper，并在 KV cache 初始化时向 xlite runtime 注册 KV cache。",
      "tags": ["service", "model-runner", "kv-cache"],
      "complexity": "simple"
    },
    {
      "id": "file:xlite/xlite_worker.py",
      "type": "file",
      "name": "xlite_worker.py",
      "filePath": "xlite/xlite_worker.py",
      "summary": "继承 NPU worker，在设备初始化时初始化 workspace manager 并以 XliteModelRunner 作为模型运行器，使 worker 走 xlite 推理路径。",
      "tags": ["service", "worker", "device-init"],
      "complexity": "simple"
    },
    {
      "id": "file:xlite/xlite.py",
      "type": "file",
      "name": "xlite.py",
      "filePath": "xlite/xlite.py",
      "summary": "xlite 集成核心模块，定义将 vLLM 模型适配到 xlite C++ runtime 的模型适配器体系（Llama / Qwen MoE / GLM4 MoE / MiniMax M2）以及前向调用包装器 XliteWrapper。",
      "tags": ["service", "model-adapter", "runtime-integration", "factory", "moe"],
      "complexity": "complex",
      "languageNotes": "采用抽象基类 XliteModel + 多架构子类 + 工厂函数 xlite_model_init 的策略模式；XliteWrapper 通过 __getattr__ 透明代理底层 runnable，并在 __call__ 中构建 AttnMeta 调用 NPU 上的 xlite runtime 前向。"
    },
    {
