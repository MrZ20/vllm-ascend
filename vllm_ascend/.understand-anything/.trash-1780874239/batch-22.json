      "tags": ["wrapper", "runtime-integration", "forward", "attention"],
      "complexity": "complex",
      "languageNotes": "__getattr__ 实现对底层模型的属性透传；__call__ 中区分 inputs_embeds 路径并调用 xlite_model.forward / forward_with_inputs_embeds。"
    },
